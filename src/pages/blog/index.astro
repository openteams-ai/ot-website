---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';

const featured = {
  title: 'Own the Intelligence. Rent the Model.',
  body: 'The advantage in AI isn’t the model, it’s the context underneath it. Why context engineering and owned context beat rented AI. By Travis Oliphant.',
  href: '/own-your-ai-context-engineering/',
};

const MONTHS = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
const fmt = (iso) => {
  const [y, m, d] = iso.split('-');
  return `${MONTHS[Number(m) - 1]} ${Number(d)}, ${y}`;
};

const allPosts = [
  {
    date: '2025-10-02',
    title: 'My Mom Is Scared of AI. She’s Scared of the Wrong Thing.',
    body: 'The immediate danger isn’t AI itself. It’s humans using AI as a tool for unchecked power.',
    href: '/blog/ai-data-sovereignty/',
  },
  {
    date: '2025-07-03',
    title: 'Open Source Isn’t the Real Risk in National Defense.',
    body: 'Government contracts aren’t immune to AI hype. Most defense teams hit the same wall: slow-moving, locked-in systems built by vendors who sell mystery boxes.',
    href: '/blog/open-source-isnt-the-real-risk-in-national-defense/',
  },
  {
    date: '2025-06-27',
    title: 'Inside a $1T Firm’s Fight to Build Real AI Infrastructure',
    body: 'The biggest threat to your AI rollout isn’t the tech. It’s the gap between vision and execution.',
    href: '/blog/inside-a-1t-firms-fight-to-build-real-ai-infrastructure/',
  },
  {
    date: '2025-06-27',
    title: 'How a Fast-Growing AI Company Rebuilt from the Stack Up',
    body: 'This team had built something remarkable: intelligent agents that could parse documents in seconds, respond around the clock, and surface insights on demand.',
    href: '/blog/how-a-fast-growing-ai-company-rebuilt-from-the-stack-up/',
  },
  {
    date: '2025-06-26',
    title: 'They Didn’t Want a Vendor. They Wanted Ownership.',
    body: 'Energy infrastructure is changing faster than policy can keep up. Power sources are becoming decentralized. Grids are growing brittle.',
    href: '/blog/they-didnt-want-a-vendor-they-wanted-ownership/',
  },
  {
    date: '2025-06-25',
    title: 'What NASA Did That Every Tech Leader Should Steal',
    body: 'Behind the missions, the telescopes, and the frontier-breaking discoveries, there’s a quiet frontier most people never see: software infrastructure.',
    href: '/blog/what-nasa-did-that-every-tech-leader-should-steal/',
  },
  {
    date: '2025-05-23',
    title: 'The Lung That Failed and What It Taught Us About AI',
    body: 'A biotech firm saved millions by turning messy data into predictions. Here’s how OpenTeams helped them own their AI infrastructure — before it failed.',
    href: '/blog/the-lung-that-failed-and-what-it-taught-us-about-ai/',
  },
  {
    date: '2025-04-25',
    title: 'The Democratization of AI Has Already Happened',
    body: 'AI isn’t locked up by Big Tech. It’s already open. The future belongs to those who see that the AI revolution is being led by open source — quietly, but definitively.',
    href: '/blog/the-democratization-of-ai-has-already-happened/',
  },
];

// Newest first.
const posts = [...allPosts].sort((a, b) => b.date.localeCompare(a.date));
---

<BaseLayout
  title="Inference & Signals | The AI Journal for Decision-Makers"
  description="Break through the noise. Inference & Signals gives you the edge with insights that matter in open source AI."
>
  <PageHero
    eyebrow="Inference & Signals"
    title="The AI Journal for Decision-Makers"
    lead="Get deep insights, real stories, and expert analysis designed for thought leaders, developers, and executives."
  >
    <div class="hero__cta">
      <a href="#" class="btn btn--coral">Subscribe</a>
    </div>
  </PageHero>

  <!-- Featured -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">Featured</p>
      <a href={featured.href} class="card featured-card">
        <h2>{featured.title}</h2>
        <p class="muted">{featured.body}</p>
        <span class="featured-card__link">Read More &rarr;</span>
      </a>
    </div>
  </section>

  <!-- Latest -->
  <section class="section section--cloud">
    <div class="container">
      <p class="eyebrow">Latest</p>
      <h2>Read the latest insights</h2>
      <div class="grid grid--3 posts">
        {posts.map((p) => (
          <a href={p.href} class="card post-card">
            <p class="card__num">{fmt(p.date)}</p>
            <h3>{p.title}</h3>
            <p class="muted">{p.body}</p>
            <span class="post-card__link">Read More &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section final-cta">
    <div class="container center">
      <h2>Never Miss a Signal</h2>
      <p class="lead" style="margin-inline:auto">
        Break through the noise. Get the insights that matter in open source AI,
        straight to your inbox.
      </p>
      <a href="/contact-us/" class="btn btn--primary">Talk to Us</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero__cta { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 1.75rem; }

  .posts { margin-top: 2.5rem; }

  .featured-card {
    display: flex;
    flex-direction: column;
    color: inherit;
    margin-top: 1.5rem;
  }
  .featured-card:hover { border-color: var(--ot-coral-500); }
  .featured-card__link,
  .post-card__link {
    font-family: var(--ot-font-display);
    font-weight: 600;
    color: var(--ot-coral-500);
    margin-top: 1rem;
  }

  .post-card { display: flex; flex-direction: column; color: inherit; }
  .post-card:hover { border-color: var(--ot-coral-500); }
  .post-card .muted { flex: 1; }

  .final-cta { background: var(--ot-lavender-50); }
  .final-cta h2 { margin-bottom: 1rem; }
  .final-cta .btn { margin-top: 1.5rem; }
</style>
