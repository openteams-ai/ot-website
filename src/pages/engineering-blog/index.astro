---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';

const allPosts = [
  {
    date: '2026-05-13',
    title: 'PDF Table Extraction: Docling vs Marker vs LlamaParse Compared',
    body: 'Compare three Python tools for PDF table extraction: Docling, Marker, and LlamaParse. Learn which handles merged cells and multi-level headers best.',
    author: 'Khuyen Tran',
    href: '/engineering-blog/docling-vs-marker-vs-llamaparse/',
  },
  {
    date: '2026-05-01',
    title: 'Sandboxing Code Mode for Local LLM Agents',
    body: 'Code mode can make local LLM agents more practical, but executing model-written code brings sandboxing back into the architecture.',
    author: 'Nick Byrne & Khuyen Tran',
    href: '/engineering-blog/code-mode-sandboxing-local-llms/',
  },
  {
    date: '2026-04-19',
    title: 'Slow Down — Simple Lessons for Guiding AI and Shipping Better Code',
    body: 'Practical lessons for shipping better code, staying in control, keeping your skills sharp, and getting real value from AI coding tools without losing yourself in the hype.',
    author: 'Johnny Bouder',
    href: '/engineering-blog/slow-down-ship-better-code/',
  },
  {
    date: '2026-04-16',
    title: 'We Benchmarked 6 Python Package Managers on a Real ML Project',
    body: 'Head-to-head benchmark of pixi, uv, conda, mamba, pip, and poetry on a real ML/AI project with 25+ mixed conda-forge and PyPI dependencies.',
    author: 'Brandon Geraci',
    href: '/engineering-blog/benchmark-python-package-managers/',
  },
  {
    date: '2026-04-15',
    title: 'Plugin Playground AI Integration for Faster Plugin Prototyping',
    body: 'How we integrated AI into Plugin Playground to help you create, edit, test, package, and share JupyterLab plugins faster in JupyterLite and Binder.',
    author: 'Anuj Kumar Singh',
    href: '/engineering-blog/plugin-playground-ai-integration/',
  },
  {
    date: '2026-04-09',
    title: 'What I Learned Making a Local LLM Do Real Work',
    body: 'What makes a local LLM agent reliable enough for real work: evals, deterministic Python logic, and why a better model beats engineering.',
    author: 'Adam Lewis',
    href: '/engineering-blog/what-i-learned-making-a-local-llm-do-real-work/',
  },
  {
    date: '2026-04-09',
    title: 'From Skill to Agent: When a Text File Isn’t Enough',
    body: 'When does a Claude Code skill stop being enough? See why credential security pushes real workflows toward proper agent architectures.',
    author: 'Adam Lewis',
    href: '/engineering-blog/from-skill-to-agent/',
  },
];

// Newest first, with the tag number reflecting the sorted position.
const posts = [...allPosts]
  .sort((a, b) => b.date.localeCompare(a.date))
  .map((p, i) => ({ ...p, tag: String(i + 1).padStart(2, '0') }));
---

<BaseLayout
  title="Engineering Blog"
  description="Hands-on engineering articles from the OpenTeams team on Python tooling, AI agents, LLMs, and open-source workflows used in real production."
>
  <PageHero
    eyebrow="OpenTeams Engineering Blog"
    title="Python, AI & Open Source"
    lead="Hands-on engineering articles from the OpenTeams team on Python tooling, AI agents, LLMs, and open-source workflows used in real production."
  />

  <!-- Posts -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">Latest Articles</p>
      <h2>Built in production, shared in the open.</h2>
      <div class="grid grid--3 posts">
        {posts.map((p) => (
          <a href={p.href} class="card post-card">
            <p class="card__num">{p.tag}</p>
            <h3>{p.title}</h3>
            <p class="muted">{p.body}</p>
            <p class="post-card__author">By {p.author}</p>
            <span class="post-card__link">Read More &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section final-cta">
    <div class="container center">
      <h2>Building the Infrastructure for a Distributed AI Economy</h2>
      <p class="lead" style="margin-inline:auto">
        We build owned intelligence in the open. Want the team behind these
        articles working on your stack?
      </p>
      <a href="/contact-us/" class="btn btn--primary">Talk to Us</a>
    </div>
  </section>
</BaseLayout>

<style>
  .posts { margin-top: 2.5rem; }

  .post-card { display: flex; flex-direction: column; color: inherit; }
  .post-card:hover { border-color: var(--ot-coral-500); }
  .post-card .muted { flex: 1; }
  .post-card__author {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--ot-ink-500);
    margin: 1rem 0 0;
  }
  .post-card__link {
    font-family: var(--ot-font-display);
    font-weight: 600;
    color: var(--ot-coral-500);
    margin-top: 0.5rem;
  }

  .final-cta { background: var(--ot-lavender-50); }
  .final-cta h2 { margin-bottom: 1rem; }
  .final-cta .btn { margin-top: 1.5rem; }
</style>
