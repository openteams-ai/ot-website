---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';

const learn = [
  {
    num: '01',
    title: 'Your Owned-Intelligence Score',
    body: 'A single, benchmarked number that shows how much of your AI stack you truly own versus how much you’re renting from vendors.',
  },
  {
    num: '02',
    title: 'Where value is leaking',
    body: 'A clear map of the models, data, and workflows where your investment is compounding for someone else instead of your organization.',
  },
  {
    num: '03',
    title: 'Your fastest path to ownership',
    body: 'Prioritized, practical next steps — from open-source foundations to a private Intelligence Hub — to move from rented to owned with the least risk.',
  },
];
---

<BaseLayout
  title="Get Your Owned-Intelligence Score"
  description="Measure how much of your AI your organization actually owns. Take the OpenTeams Owned-Intelligence Assessment and get a benchmarked score plus a path to ownership."
>
  <PageHero
    eyebrow="Owned-Intelligence Assessment"
    title="Get Your Owned-Intelligence Score."
    lead="Most organizations don’t own their AI — they rent it. Every query deepens the dependence while the asset accrues to the vendor. In a few minutes, find out where you stand and what it would take to own the layer where your intelligence runs."
  />

  <!-- What you learn -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">What You’ll Learn</p>
      <h2>Rented or owned? Know the difference.</h2>
      <div class="grid grid--3 learn">
        {learn.map((l) => (
          <div class="card">
            <p class="card__num">{l.num}</p>
            <h3>{l.title}</h3>
            <p class="muted">{l.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Assessment form -->
  <section class="section section--cloud">
    <div class="container assess-grid">
      <div class="assess-intro">
        <p class="eyebrow">Start the Assessment</p>
        <h2>Answer a few questions.</h2>
        <p class="lead">
          Tell us about how your organization uses AI today. We’ll follow up with
          your Owned-Intelligence Score and a tailored path to ownership — no
          obligation, no lock-in.
        </p>
      </div>

      <form class="assess-form card" onsubmit="return false">
        <div class="field">
          <label for="company">Company</label>
          <input id="company" name="company" type="text" autocomplete="organization" required />
        </div>
        <div class="field">
          <label for="email">Work email</label>
          <input id="email" name="email" type="email" autocomplete="email" required />
        </div>

        <fieldset class="field">
          <legend>How do you run AI today?</legend>
          <label class="choice">
            <input type="radio" name="deployment" value="subscriptions" />
            <span>Mostly third-party AI subscriptions and APIs</span>
          </label>
          <label class="choice">
            <input type="radio" name="deployment" value="mixed" />
            <span>A mix of vendor tools and in-house work</span>
          </label>
          <label class="choice">
            <input type="radio" name="deployment" value="owned" />
            <span>Mostly self-hosted / open-source in our environment</span>
          </label>
        </fieldset>

        <fieldset class="field">
          <legend>Where does your data and workflow live?</legend>
          <label class="choice">
            <input type="radio" name="data" value="vendor" />
            <span>Inside vendor platforms we don’t control</span>
          </label>
          <label class="choice">
            <input type="radio" name="data" value="hybrid" />
            <span>Split across vendor and our own infrastructure</span>
          </label>
          <label class="choice">
            <input type="radio" name="data" value="internal" />
            <span>Fully inside our own environment</span>
          </label>
        </fieldset>

        <fieldset class="field">
          <legend>What’s driving the move to owned AI?</legend>
          <label class="choice">
            <input type="checkbox" name="drivers" value="compliance" />
            <span>Data sovereignty & compliance</span>
          </label>
          <label class="choice">
            <input type="checkbox" name="drivers" value="cost" />
            <span>Runaway subscription costs</span>
          </label>
          <label class="choice">
            <input type="checkbox" name="drivers" value="outcomes" />
            <span>Better outcomes on our specific problems</span>
          </label>
          <label class="choice">
            <input type="checkbox" name="drivers" value="lockin" />
            <span>Escaping vendor lock-in</span>
          </label>
        </fieldset>

        <button type="submit" class="btn btn--coral">Get My Score</button>
      </form>
    </div>
  </section>

  <!-- Reassurance / CTA -->
  <section class="section final-cta">
    <div class="container center">
      <h2>The AI You Keep Starts Here</h2>
      <p class="lead" style="margin-inline:auto">
        Built by the creators of NumPy, SciPy, and the open-source foundations of
        modern AI — here to help you own the layer where your intelligence runs.
      </p>
      <a href="/contact-us/" class="btn btn--primary" style="margin-top:1.5rem">Talk to Us</a>
    </div>
  </section>
</BaseLayout>

<style>
  .learn { margin-top: 2.5rem; }

  .assess-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  .assess-form { display: grid; gap: 1.5rem; }
  .field { display: grid; gap: 0.5rem; border: 0; margin: 0; padding: 0; }
  .field label,
  .field legend {
    font-family: var(--ot-font-display);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--ot-navy-900);
    padding: 0;
  }
  .field input[type='text'],
  .field input[type='email'] {
    font-family: var(--ot-font-body);
    font-size: 1rem;
    color: var(--ot-ink-900);
    padding: 0.75rem 1rem;
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius-sm);
    background: var(--ot-white);
    width: 100%;
  }
  .field input[type='text']:focus,
  .field input[type='email']:focus {
    outline: none;
    border-color: var(--ot-blue-500);
    box-shadow: 0 0 0 3px rgba(77, 117, 254, 0.15);
  }

  .choice {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-family: var(--ot-font-body);
    font-weight: 400;
    font-size: 0.98rem;
    color: var(--ot-ink-700);
  }
  .choice input { margin-top: 0.25rem; flex: none; accent-color: var(--ot-blue-500); }

  .assess-form .btn { justify-self: start; }

  .final-cta { background: var(--ot-lavender-50); }
  .final-cta h2 { margin-bottom: 1rem; }

  @media (max-width: 820px) {
    .assess-grid { grid-template-columns: 1fr; }
  }
</style>
