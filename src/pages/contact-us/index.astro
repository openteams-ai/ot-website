---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';

const reasons = [
  {
    num: '01',
    title: 'Talk to an engineer, not a sales script',
    body: 'Our forward-deployed engineers built the open-source foundations of modern AI. Bring your hardest problem and we’ll tell you honestly whether we can help.',
  },
  {
    num: '02',
    title: 'Scope your owned-intelligence roadmap',
    body: 'From an open-source foundation to a private enterprise hub, we map the shortest path to AI your organization actually owns.',
  },
  {
    num: '03',
    title: 'No lock-in, ever',
    body: 'We build your system, train your team, and support you as long as needed. The asset stays yours.',
  },
];
---

<BaseLayout
  title="Contact us"
  description="Talk to the OpenTeams team about building AI your organization actually owns. Reach us at info@openteams.com."
>
  <PageHero
    eyebrow="Contact Us"
    title="Let’s build the AI you keep."
    lead="Tell us about your organization and what you’re trying to own. We’ll connect you with the right engineer to scope the work — no obligation, no lock-in."
  />

  <!-- Contact split: form + info -->
  <section class="section">
    <div class="container contact-grid">
      <div class="contact-form-wrap">
        <p class="eyebrow">Send us a message</p>
        <h2>Start the conversation.</h2>
        <form class="contact-form" onsubmit="return false">
          <div class="field">
            <label for="name">Name</label>
            <input id="name" name="name" type="text" autocomplete="name" required />
          </div>
          <div class="field">
            <label for="email">Work email</label>
            <input id="email" name="email" type="email" autocomplete="email" required />
          </div>
          <div class="field">
            <label for="company">Company</label>
            <input id="company" name="company" type="text" autocomplete="organization" />
          </div>
          <div class="field">
            <label for="message">How can we help?</label>
            <textarea id="message" name="message" rows="5" required></textarea>
          </div>
          <button type="submit" class="btn btn--primary">Send message</button>
        </form>
      </div>

      <aside class="contact-info">
        <p class="eyebrow">Reach us directly</p>
        <h2 class="contact-info__h">Prefer email?</h2>
        <p class="muted">
          Drop us a line and a member of our team will get back to you.
        </p>
        <a href="mailto:info@openteams.com" class="contact-info__email">info@openteams.com</a>
        <ul class="contact-reasons">
          {reasons.map((r) => (
            <li class="contact-reasons__item">
              <span class="contact-reasons__num">{r.num}</span>
              <div>
                <h3>{r.title}</h3>
                <p class="muted">{r.body}</p>
              </div>
            </li>
          ))}
        </ul>
      </aside>
    </div>
  </section>

  <!-- Assessment nudge -->
  <section class="section section--cloud">
    <div class="container center">
      <p class="eyebrow">Not sure where to start?</p>
      <h2>See how much of your AI you actually own.</h2>
      <p class="lead" style="margin-inline:auto">
        The Owned-Intelligence Assessment scores your current stack and shows
        where value is leaking into someone else’s subscription.
      </p>
      <a href="/owned-intelligence-assessment/" class="btn btn--coral" style="margin-top:1.5rem">
        Get Your Owned-Intelligence Score
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  .contact-form { margin-top: 1.5rem; display: grid; gap: 1.25rem; }
  .field { display: grid; gap: 0.4rem; }
  .field label {
    font-family: var(--ot-font-display);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--ot-navy-900);
  }
  .field input,
  .field textarea {
    font-family: var(--ot-font-body);
    font-size: 1rem;
    color: var(--ot-ink-900);
    padding: 0.75rem 1rem;
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius-sm);
    background: var(--ot-white);
    width: 100%;
  }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--ot-blue-500);
    box-shadow: 0 0 0 3px rgba(77, 117, 254, 0.15);
  }
  .field textarea { resize: vertical; }
  .contact-form .btn { justify-self: start; margin-top: 0.5rem; }

  .contact-info__h { margin-top: 0.25rem; }
  .contact-info__email {
    display: inline-block;
    font-family: var(--ot-font-display);
    font-weight: 600;
    font-size: 1.25rem;
    margin-block: 0.5rem 2rem;
  }

  .contact-reasons {
    list-style: none;
    display: grid;
    gap: 1.5rem;
    border-top: 1px solid var(--ot-border);
    padding-top: 1.75rem;
  }
  .contact-reasons__item { display: flex; gap: 1rem; align-items: flex-start; }
  .contact-reasons__num {
    font-family: var(--ot-font-mono);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--ot-coral-500);
    line-height: 1.3;
    flex: none;
  }
  .contact-reasons h3 { font-size: 1.1rem; margin-bottom: 0.25rem; }
  .contact-reasons p { margin-bottom: 0; }

  @media (max-width: 820px) {
    .contact-grid { grid-template-columns: 1fr; }
  }
</style>
