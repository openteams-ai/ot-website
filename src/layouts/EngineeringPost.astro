---
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;
const { title, description, date, authors, deck } = frontmatter;

const MONTHS = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
const fmt = (iso: string) => {
  const [y, m, d] = iso.split('-');
  return `${MONTHS[Number(m) - 1]} ${Number(d)}, ${y}`;
};
---

<BaseLayout title={title} description={description}>
  <article class="post">
    <header class="section section--dark post__hero">
      <div class="container post__head">
        <a href="/engineering-blog/" class="post__back">&larr; All articles</a>
        <p class="eyebrow">Engineering Blog</p>
        <h1>{title}</h1>
        {deck && <p class="lead">{deck}</p>}
        <p class="post__meta">
          <time datetime={date}>{fmt(date)}</time>
          {authors && <span> · {authors}</span>}
        </p>
      </div>
    </header>

    <div class="section">
      <div class="container post__body">
        <slot />
      </div>
    </div>

    <section class="section final-cta">
      <div class="container center">
        <h2>Want this team on your stack?</h2>
        <p class="lead" style="margin-inline:auto">
          We build owned intelligence in the open. Talk to the engineers behind
          these articles about your Python, AI, and open-source infrastructure.
        </p>
        <a href="/contact-us/" class="btn btn--primary">Talk to Us</a>
      </div>
    </section>
  </article>
</BaseLayout>

<script is:inline>
  if (document.querySelector('.mermaid')) {
    var s = document.createElement('script');
    s.src = '/vendor/mermaid.min.js';
    s.onload = function () {
      window.mermaid.initialize({ startOnLoad: false, theme: 'neutral' });
      window.mermaid.run();
    };
    document.head.appendChild(s);
  }
</script>

<style>
  .post__hero { padding-block: clamp(3rem, 8vw, 5.5rem); }
  .post__head { max-width: 820px; }
  .post__back {
    display: inline-block;
    font-family: var(--ot-font-display);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--ot-coral-500);
    margin-bottom: 1.5rem;
  }
  .post__hero .lead { margin-top: 1rem; }
  .post__meta {
    margin-top: 1.5rem;
    font-family: var(--ot-font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.7);
  }

  /* Article typography */
  .post__body {
    max-width: 760px;
    font-size: 1.08rem;
    line-height: 1.75;
    color: var(--ot-ink-700);
  }
  .post__body :global(h2) {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-top: 2.75rem;
    margin-bottom: 1rem;
  }
  .post__body :global(h3) {
    font-size: clamp(1.2rem, 2vw, 1.4rem);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .post__body :global(p) { margin: 0 0 1.4rem; }
  .post__body :global(ul),
  .post__body :global(ol) { margin: 0 0 1.4rem; padding-left: 1.4rem; }
  .post__body :global(li) { margin-bottom: 0.5rem; }
  .post__body :global(li)::marker { color: var(--ot-blue-500); }
  .post__body :global(a) { text-decoration: underline; text-underline-offset: 2px; }
  .post__body :global(strong) { color: var(--ot-ink-900); }
  .post__body :global(img) {
    border-radius: var(--ot-radius);
    border: 1px solid var(--ot-border);
    margin: 1.5rem 0;
  }
  .post__body :global(blockquote) {
    margin: 2rem 0;
    padding: 0.5rem 0 0.5rem 1.5rem;
    border-left: 3px solid var(--ot-coral-500);
    font-style: italic;
    color: var(--ot-navy-900);
  }

  /* Inline code + code blocks */
  .post__body :global(:not(pre) > code) {
    font-family: var(--ot-font-mono);
    font-size: 0.9em;
    background: var(--ot-lavender-50);
    border: 1px solid var(--ot-border);
    border-radius: 6px;
    padding: 0.12em 0.4em;
  }
  .post__body :global(pre) {
    border-radius: var(--ot-radius);
    padding: 1.15rem 1.3rem;
    overflow-x: auto;
    margin: 0 0 1.5rem;
    font-size: 0.9rem;
    line-height: 1.6;
  }
  .post__body :global(pre code) { font-family: var(--ot-font-mono); }

  /* Tables */
  .post__body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 0 0 1.6rem;
    font-size: 0.96rem;
    display: block;
    overflow-x: auto;
  }
  .post__body :global(th),
  .post__body :global(td) {
    text-align: left;
    padding: 0.6rem 0.9rem;
    border: 1px solid var(--ot-border);
    vertical-align: top;
  }
  .post__body :global(th) {
    background: var(--ot-lavender-50);
    font-family: var(--ot-font-display);
    color: var(--ot-navy-900);
    white-space: nowrap;
  }

  /* Mermaid: hide raw source until rendered, then center the SVG */
  .post__body :global(pre.mermaid) {
    background: none;
    border: none;
    padding: 0;
    text-align: center;
    color: transparent;
  }
  .post__body :global(pre.mermaid[data-processed]) { color: inherit; }
  .post__body :global(pre.mermaid svg) { max-width: 100%; height: auto; }

  .final-cta { background: var(--ot-lavender-50); }
  .final-cta h2 { margin-bottom: 1rem; }
  .final-cta .btn { margin-top: 1.5rem; }
</style>
