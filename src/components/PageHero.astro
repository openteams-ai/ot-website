---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
}
const { eyebrow, title, lead } = Astro.props;
---
<section class="section section--dark page-hero">
  <div class="container">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    {lead && <p class="lead">{lead}</p>}
    <slot />
  </div>
</section>

<style>
  .page-hero { padding-block: clamp(3.5rem, 9vw, 6.5rem); }
  .page-hero .lead { margin-top: 1rem; }
</style>
